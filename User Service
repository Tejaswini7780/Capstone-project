from flask import Flask, jsonify

app = Flask(__name__)

users = [
    {"id": 1, "name": "Teja"},
    {"id": 2, "name": "Ravi"}
]

@app.route("/")
def home():
    return jsonify({"message": "User Service Running"}), 200

@app.route("/users", methods=["GET"])
def get_users():
    return jsonify(users), 200

@app.route("/health")
def health():
    return jsonify({"status": "UP"}), 200

if __name__ == "__main__":
    app.run(port=5004)
